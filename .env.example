NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — used for customer portal token validation (bypasses RLS)
# Find in Supabase Dashboard → Settings → API → service_role (secret) key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# SMS / OTP
# Provider: twofactor (recommended) | console (dev) | msg91 | twilio
SMS_PROVIDER=twofactor

# 2Factor.in — https://2factor.in/cp/ → API
TWOFACTOR_API_KEY=your_2factor_api_key_here
# DLT-registered template name, or AUTOGEN to use 2Factor's default
TWOFACTOR_TEMPLATE_NAME=AUTOGEN

# OTP signing secret — set to a long random string in production
OTP_SECRET=dabbr-otp-secret-change-in-prod

# App base URL (used to build magic-link redirects for provider phone login)
NEXT_PUBLIC_APP_URL=https://your-app-url.com
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# Google Maps — enable Maps JavaScript API + Geocoding API + Places API
# Restrict key to dabbr.in in Google Cloud Console → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
